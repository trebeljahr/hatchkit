# Managed by Ansible — do not edit manually.
# See docs/hardening-guide.md for explanations of each setting.

# ===========================================================================
# Authentication
# ===========================================================================
PermitRootLogin {{ ssh_permit_root_login }}
PasswordAuthentication {{ ssh_password_authentication }}
KbdInteractiveAuthentication {{ ssh_kbd_interactive_authentication }}
PubkeyAuthentication {{ ssh_pubkey_authentication }}
PermitEmptyPasswords no
MaxAuthTries {{ ssh_max_auth_tries }}
AuthenticationMethods publickey
AllowUsers {{ ssh_allowed_users | join(' ') }}{% if ssh_coolify_compatibility and 'root' not in ssh_allowed_users %} root{% endif %}

# ===========================================================================
# Session limits
# ===========================================================================
ClientAliveInterval {{ ssh_client_alive_interval }}
ClientAliveCountMax {{ ssh_client_alive_count_max }}
LoginGraceTime {{ ssh_login_grace_time }}
MaxSessions {{ ssh_max_sessions }}
MaxStartups 3:50:10

# ===========================================================================
# Disable unused features
# ===========================================================================
X11Forwarding no
AllowTcpForwarding no
AllowAgentForwarding no
PermitTunnel no
GatewayPorts no
PermitUserEnvironment no

# ===========================================================================
# Strong cryptography
# ===========================================================================
KexAlgorithms {{ ssh_kex_algorithms | regex_replace('\\s+', '') }}
Ciphers {{ ssh_ciphers | regex_replace('\\s+', '') }}
MACs {{ ssh_macs | regex_replace('\\s+', '') }}
HostKeyAlgorithms ssh-ed25519,ssh-ed25519-cert-v01@openssh.com
{% if ssh_coolify_compatibility %}

# ===========================================================================
# Coolify compatibility — allow root login from Docker internal networks
# ===========================================================================
# Coolify manages the server by SSHing in as root from its Docker container
# (via host.docker.internal). The global PermitRootLogin no still applies to
# all other addresses. Match blocks must come last in sshd config.
Match Address {{ ssh_coolify_match_addresses }}
    PermitRootLogin prohibit-password
{% endif %}
