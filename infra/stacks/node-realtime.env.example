# node-realtime.env — Stack config for a Node.js realtime app.
#
# This is the "node-realtime-single" stamp: a single Node container with
# WebSocket support, MongoDB, optional Redis, and S3 storage.
# Works for any app that fits this shape — game servers, collaboration
# tools, chat apps, dashboards with live updates, etc.
#
# HOW TO USE:
# 1. Copy for your app:  cp node-realtime.env.example myapp.env
# 2. Fill in your values
# 3. Run: ./scripts/setup-coolify-stack.sh --config stacks/myapp.env
#
# Values set here skip the interactive prompts in the setup script.
# Secrets should still use environment variables where possible.
#
# This file is gitignored. The .example version is committed as a template.

# --- Coolify connection ---
# Set COOLIFY_TOKEN as an environment variable instead of here:
#   export COOLIFY_TOKEN="your-api-token"
COOLIFY_URL="https://admin.example.com"

# --- Project ---
PROJECT_NAME="myapp"
ENVIRONMENT_NAME="production"

# --- Application ---
APP_NAME="myapp-web"
GITHUB_REPO_URL="https://github.com/your-org/myapp.git"
APP_PORT="3000"

# --- Domain ---
# The script derives the API subdomain automatically:
#   APP_DOMAIN=myapp.example.com  →  api.myapp.example.com
#
# The app container receives traffic for ALL of these:
#   https://myapp.example.com           (frontend)
#   https://api.myapp.example.com       (API via subdomain)
#   https://myapp.example.com/api       (API via path)
#   https://myapp.example.com/api/ws    (WebSocket via path)
#   https://api.myapp.example.com/ws    (WebSocket via subdomain)
#
# IMPORTANT: Both the base domain AND api.* must have DNS records.
# In your terraform.tfvars, this means:
#   subdomains = {
#     "myapp"     = "Frontend + API paths"
#     "api.myapp" = "Dedicated API subdomain"
#   }
APP_DOMAIN="myapp.example.com"

# --- Databases ---
MONGO_ENABLED="yes"
REDIS_ENABLED="no"
# Connection strings are auto-wired:
#   MONGODB_URI = mongodb://myapp-mongo:27017/myapp
#   REDIS_URL   = redis://myapp-redis:6379

# --- S3 storage ---
# Options: hetzner (recommended), r2, minio, custom, none
# See script comments for detailed comparison.
S3_PROVIDER="hetzner"
S3_BUCKET=""
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="eu-central-1"
PUBLIC_ASSET_URL=""

# --- App secrets ---
# These are specific to your app. Add/remove as needed.
# Leave blank to be prompted interactively (recommended for secrets).
TOKEN_SECRET=""
ALTCHA_HMAC=""
