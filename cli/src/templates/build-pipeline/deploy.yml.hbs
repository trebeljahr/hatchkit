# Build → push → deploy pipeline scaffolded by hatchkit.
#
#   1. verify        — install deps, build, run unit + client tests.
#   2. e2e           — full Playwright E2E run against Docker services.
#   3. build-server  — build packages/server image, push to GHCR as
#                       `ghcr.io/<owner>/<repo>-server:<branch>` +
#                       `:<sha>`.
#   4. build-client  — build packages/client image, push to GHCR as
#                       `ghcr.io/<owner>/<repo>-client:<branch>` +
#                       `:<sha>`.
#   5. deploy        — after BOTH image jobs succeed, trigger Coolify
#                       to redeploy via its API (or webhook fallback).
#
# Required repo secrets (hatchkit sets these via `gh secret set`
# during adopt / create; rotate via the GitHub UI / `gh` whenever
# needed):
#   COOLIFY_BASE_URL              — base URL of the Coolify install
#                                   (e.g. https://coolify.example.com)
#   COOLIFY_RESOURCE_UUID         — uuid of the application resource
#                                   in Coolify to redeploy
#   COOLIFY_API_TOKEN             — bearer token for the Coolify API
#   COOLIFY_WEBHOOK_URL           — (optional fallback) per-app deploy
#                                   webhook URL, used only when
#                                   COOLIFY_BASE_URL is unset
#   DOTENV_PRIVATE_KEY_PRODUCTION — dotenvx private key; passed to the
#                                   docker build as a BuildKit secret
#                                   (mounted as tmpfs, never written
#                                   to a layer or `docker history`).
#                                   The Dockerfile uses it to decrypt
#                                   .env.production in memory and bake
#                                   build-time values (NEXT_PUBLIC_*
#                                   etc.) into the output. Stored in
#                                   your OS keychain under
#                                   `dotenvx:<project>:production-private-key`
#                                   — `hatchkit keys show <project>` to retrieve.
#
# GHCR auth uses the workflow's built-in GITHUB_TOKEN. For Coolify
# to pull a private package, SSH into the Coolify host once and run
# `docker login ghcr.io` — Coolify reads ~/.docker/config.json
# automatically. See:
# https://coolify.io/docs/knowledge-base/custom-docker-registry
name: build-and-deploy

on:
  push:
    branches: [__DEFAULT_BRANCH__]
  workflow_dispatch:

permissions:
  contents: read
  packages: write

concurrency:
  group: deploy-${{ github.ref }}
  cancel-in-progress: false

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version-file: .nvmrc
      - uses: pnpm/action-setup@v4
      - run: pnpm install --frozen-lockfile
      - run: pnpm run build
      - run: pnpm run test:unit
      - run: pnpm run test:client

  e2e:
    runs-on: ubuntu-latest
    needs: [verify]
    services:
      mongo-e2e:
        image: mongo:7
        ports:
          - 27018:27017
      redis-e2e:
        image: redis:7-alpine
        ports:
          - 6380:6379
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version-file: .nvmrc
      - uses: pnpm/action-setup@v4
      - run: pnpm install --frozen-lockfile
      - run: pnpm run build

      - name: Start MinIO
        run: |
          docker run -d --name e2e-minio -p 9002:9000 \
            -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
            --tmpfs /data minio/minio:latest server /data
          for i in $(seq 1 30); do
            curl -sf http://127.0.0.1:9002/minio/health/live && break
            sleep 1
          done
          docker run --rm --network host \
            --entrypoint sh minio/mc:latest -c \
            "mc alias set local http://127.0.0.1:9002 minioadmin minioadmin && \
             mc mb --ignore-existing local/starter-e2e && \
             mc anonymous set download local/starter-e2e"

      - run: npx playwright install --with-deps chromium

      - name: Run E2E tests
        run: npx playwright test
        env:
          CI: "true"
          MONGODB_URI: mongodb://127.0.0.1:27018/starter-e2e
          REDIS_URL: redis://127.0.0.1:6380
          BETTER_AUTH_SECRET: e2e-test-secret
          BETTER_AUTH_URL: http://127.0.0.1:5006
          FRONTEND_URL: http://127.0.0.1:3001
          S3_ENDPOINT: http://127.0.0.1:9002
          S3_FORCE_PATH_STYLE: "true"
          S3_BUCKET_NAME: starter-e2e
          S3_PUBLIC_URL: http://127.0.0.1:9002/starter-e2e
          AWS_ACCESS_KEY_ID: minioadmin
          AWS_SECRET_ACCESS_KEY: minioadmin
          AWS_REGION: us-east-1

  build-server:
    runs-on: ubuntu-latest
    needs: [verify]
    steps:
      - uses: actions/checkout@v4
      - uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}
      - uses: docker/build-push-action@v6
        with:
          context: .
          file: packages/server/Dockerfile
          push: true
          tags: |
            ghcr.io/${{ github.repository }}-server:__DEFAULT_BRANCH__
            ghcr.io/${{ github.repository }}-server:${{ github.sha }}
          # BuildKit secret for decrypting .env.production at build
          # time. Mounted as tmpfs inside the Dockerfile's RUN step,
          # never written to a layer or `docker history`. The Dockerfile
          # exposes it as the DOTENV_PRIVATE_KEY_PRODUCTION env var for
          # `dotenvx run -- pnpm build`, which decrypts in memory and
          # bakes NEXT_PUBLIC_* / VITE_* values into the bundle.
          secrets: |
            dotenvx_private_key=${{ secrets.DOTENV_PRIVATE_KEY_PRODUCTION }}

  build-client:
    runs-on: ubuntu-latest
    needs: [verify]
    steps:
      - uses: actions/checkout@v4
      - uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}
      - uses: docker/build-push-action@v6
        with:
          context: .
          file: packages/client/Dockerfile
          push: true
          tags: |
            ghcr.io/${{ github.repository }}-client:__DEFAULT_BRANCH__
            ghcr.io/${{ github.repository }}-client:${{ github.sha }}
          secrets: |
            dotenvx_private_key=${{ secrets.DOTENV_PRIVATE_KEY_PRODUCTION }}

  deploy:
    runs-on: ubuntu-latest
    needs: [build-server, build-client]
    steps:
      - name: Deploy via Coolify API
        env:
          COOLIFY_BASE_URL: ${{ secrets.COOLIFY_BASE_URL }}
          COOLIFY_RESOURCE_UUID: ${{ secrets.COOLIFY_RESOURCE_UUID }}
          COOLIFY_API_TOKEN: ${{ secrets.COOLIFY_API_TOKEN }}
        if: env.COOLIFY_BASE_URL != '' && env.COOLIFY_RESOURCE_UUID != ''
        run: |
          curl -fsSL -X POST \
            "$COOLIFY_BASE_URL/api/v1/deploy?uuid=$COOLIFY_RESOURCE_UUID&force=true" \
            -H "Authorization: Bearer $COOLIFY_API_TOKEN"

      - name: Deploy via webhook (fallback)
        env:
          COOLIFY_BASE_URL: ${{ secrets.COOLIFY_BASE_URL }}
          COOLIFY_WEBHOOK_URL: ${{ secrets.COOLIFY_WEBHOOK_URL }}
        if: env.COOLIFY_BASE_URL == '' && env.COOLIFY_WEBHOOK_URL != ''
        run: curl -fsSL "$COOLIFY_WEBHOOK_URL"
