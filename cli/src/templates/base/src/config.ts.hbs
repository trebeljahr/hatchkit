  S3_BUCKET: process.env.S3_BUCKET || "",
  S3_ACCESS_KEY: process.env.S3_ACCESS_KEY || "",
  S3_SECRET_KEY: process.env.S3_SECRET_KEY || "",
  S3_REGION: process.env.S3_REGION || "us-east-1",
{{/if}}
{{#if has3d}}
