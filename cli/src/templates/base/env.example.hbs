NODE_ENV=production
PORT=3000
FRONTEND_URL=https://{{domain}}

# MongoDB
MONGODB_URI=mongodb://localhost:27017/{{name}}

# Auth (better-auth)
AUTH_SECRET=change-me-to-a-random-string
AUTH_URL=https://{{domain}}
{{#if websocket}}

# Redis
REDIS_URL=redis://localhost:6379
{{/if}}
{{#if stripe}}

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
{{/if}}
{{#if analytics}}

# Error tracking
GLITCHTIP_DSN=
# Analytics (OpenPanel)
OPENPANEL_API_URL=
OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
# Analytics (Plausible)
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SCRIPT_URL=
{{/if}}
{{#if s3}}

# S3 Storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
{{/if}}

# Active ML backend. Set to one of the platforms you deployed to
# (modal / runpod / hf / replicate). The runtime resolves
# ML_<SERVICE>_<BACKEND>_URL first, falling back to ML_<SERVICE>_ENDPOINT.
# Leave blank to use the deploy-time default (the first platform passed
# to `gpuPlatforms` at scaffold time).
ML_BACKEND=
{{#if has3d}}

# ML: 3D Model Extraction
# Per-platform URLs are populated by hatchkit at deploy time:
#   ML_3D_EXTRACTION_MODAL_URL=...
#   ML_3D_EXTRACTION_RUNPOD_URL=...
ML_3D_EXTRACTION_ENDPOINT=
{{/if}}
{{#if hasSubtitles}}

# ML: Subtitle Generation
ML_SUBTITLES_ENDPOINT=
{{/if}}
{{#if hasImageRecognition}}

# ML: Image Recognition
ML_IMAGE_RECOGNITION_ENDPOINT=
{{/if}}
{{#if hasBgRemoval}}

# ML: Background Removal
ML_BACKGROUND_REMOVAL_ENDPOINT=
{{/if}}
