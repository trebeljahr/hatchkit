{
  "name": "devops-cli",
  "version": "0.1.0",
  "description": "Interactive CLI for scaffolding full-stack projects with composable services",
  "type": "module",
  "bin": {
    "devops-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx test-scaffold.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "conf": "^13.0.0",
    "execa": "^9.0.0",
    "handlebars": "^4.7.8",
    "keytar": "^7.9.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@dotenvx/dotenvx": "^1.61.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
