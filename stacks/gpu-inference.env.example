# gpu-inference.env — Stack config for a photo-to-3D GPU inference API.
#
# This is the "gpu-inference" stamp: a FastAPI container on Coolify that
# receives photo uploads and dispatches 3D model generation to an external
# GPU platform (Modal, RunPod, or AWS Batch).
#
# HOW TO USE:
# 1. Copy for your app:  cp gpu-inference.env.example photo3d.env
# 2. Fill in your values
# 3. Run: ./scripts/setup-coolify-stack.sh --config stacks/photo3d.env
#
# This file is gitignored. The .example version is committed as a template.

# --- Coolify connection ---
# Set COOLIFY_TOKEN as an environment variable:
#   export COOLIFY_TOKEN="your-api-token"
COOLIFY_URL="https://admin.example.com"

# --- Project ---
PROJECT_NAME="photo3d"
ENVIRONMENT_NAME="production"

# --- Application ---
APP_NAME="photo3d-api"
GITHUB_REPO_URL="https://github.com/your-org/photo3d-api.git"
APP_PORT="8000"

# --- Domain ---
# Auto-derives API subdomain: api.3d.example.com
APP_DOMAIN="3d.example.com"

# --- Databases ---
# The inference API is stateless by default. Enable MongoDB if you need
# to track job history, user accounts, or generation metadata.
MONGO_ENABLED="no"
REDIS_ENABLED="no"
# Enable Redis if you want a job queue (BullMQ) instead of dispatching
# directly to Modal/RunPod from the request handler.

# --- S3 storage ---
S3_PROVIDER="hetzner"
S3_UPLOADS_BUCKET=""    # From terraform output: s3_uploads_bucket
S3_MODELS_BUCKET=""     # From terraform output: s3_models_bucket
S3_ENDPOINT=""          # From terraform output: s3_endpoint
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION=""            # From terraform output: s3_region

# CDN URL for serving generated models (e.g. Cloudflare in front of S3).
# If empty, the API generates presigned S3 URLs directly.
PUBLIC_MODELS_URL=""

# --- GPU inference platform ---
# Options: modal, runpod, aws-batch, self-hosted
#
# modal:       Best DX, 2-4s cold starts, ~$0.009/request (A10G, 30s)
# runpod:      Cheapest, <1s cold starts (FlashBoot), ~$0.004/request
# aws-batch:   AWS-native, scale to zero, 2-10 min cold starts
# self-hosted: Run the GPU container on your own server (Coolify + NVIDIA)
#
# See docs/gpu-inference-pipeline.md for detailed comparison.
GPU_PROVIDER="modal"

# Modal-specific
MODAL_TOKEN_ID=""
MODAL_TOKEN_SECRET=""

# RunPod-specific
# RUNPOD_API_KEY=""
# RUNPOD_ENDPOINT_ID=""

# AWS Batch-specific
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# BATCH_JOB_QUEUE=""
# BATCH_JOB_DEFINITION=""

# --- Model configuration ---
# Which 3D reconstruction model to use.
# sf3d:      Fast (0.5-3s), 6GB VRAM, good quality. MIT-friendly license.
# triposr:   Fast (0.5s), 6GB VRAM, decent quality. MIT license.
# trellis2:  Slow (3-60s), 24GB+ VRAM, excellent quality. MIT license.
#
# Recommended: sf3d for V1, add trellis2 as premium tier later.
DEFAULT_MODEL="sf3d"

# GPU type for the inference platform.
# A10G: 24GB VRAM, ~$1.10/hr (Modal). Runs SF3D and TripoSR easily.
# T4:   16GB VRAM, ~$0.53/hr. Budget option, runs SF3D and TripoSR.
# H100: 80GB VRAM, ~$3.95/hr. Required for TRELLIS.2 at full speed.
GPU_TYPE="A10G"

# --- App secrets ---
# API key for authenticating requests (generate with: openssl rand -hex 32)
API_SECRET_KEY=""

# Webhook secret for GPU job completion callbacks
WEBHOOK_SECRET=""
