node_modules/
dist/
.env
.env.local
*.log
.DS_Store
# claude code
.claude/settings.local.json
.claude/worktrees/

# standard defaults (mirrors ~/.config/git/ignore)
.DS_Store
._*
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
.idea/
.cursor/
*.swp
*~
node_modules/
__pycache__/
*.pyc
.venv/
venv/
*.log

# env files (mirrors ~/.config/git/ignore — defense in depth)
.env
.env.local
.env.dev
.env.development
.env.production
.env.staging
.env.test
.envrc.local
.vercel/

# dotenvx private keys
.env.keys

# Terraform — state, lock files, and rendered plan binaries.
# tfplan is what `terraform plan -out=tfplan` writes; it contains
# resolved values including secrets. Pattern matches anywhere in tree.
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
.terraform/
.terraform.lock.hcl
*.tfplan
tfplan
terraform.tfvars
*.auto.tfvars

# Catch-all for anything explicitly secret
*.secret
*.secret.*
secrets/
*.pem
*.key
!**/authorized_keys
