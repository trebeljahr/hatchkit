# Environment variables for the GPU inference API server.
# These are set in Coolify via setup-coolify-stack.sh.

# --- Server ---
PORT=8000
LOG_LEVEL=info

# --- S3 ---
S3_UPLOADS_BUCKET=photo3d-uploads
S3_MODELS_BUCKET=photo3d-models
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=nbg1

# CDN URL for serving models (optional, falls back to presigned URLs)
PUBLIC_MODELS_URL=

# --- GPU platform ---
GPU_PROVIDER=modal
DEFAULT_MODEL=sf3d
GPU_TYPE=A10G

# Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# RunPod
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=

# AWS Batch
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BATCH_JOB_QUEUE=
# BATCH_JOB_DEFINITION=

# --- Auth ---
API_SECRET_KEY=
WEBHOOK_SECRET=

# --- Limits ---
MAX_UPLOAD_BYTES=52428800
MAX_IMAGES_PER_REQUEST=6
PRESIGNED_URL_EXPIRY=3600
