# Server port
PORT=5000

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:3000

# Additional CORS / auth origins, comma-separated. Set this for native
# clients (desktop/mobile). Examples:
#   Capacitor iOS+Android: capacitor://localhost,https://localhost
#   Custom Electron proto: app://-
# Electron file:// sends Origin: null and can't be trusted with credentials;
# register a custom protocol in electron/main.ts and add it here instead.
# TRUSTED_ORIGINS=

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/starter-dev

# Redis (optional — used for distributed features)
# REDIS_URL=redis://127.0.0.1:6379

# better-auth
BETTER_AUTH_SECRET=change-me-in-production-use-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:5000

# Google OAuth (optional — leave empty to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (optional — leave empty to disable payments).
# Hatchkit auto-fills these per project: sandbox creds → .env.development,
# live creds → .env.production (encrypted). STRIPE_WEBHOOK_SECRET is
# minted by hatchkit at create/adopt time using a master restricted key.
# STRIPE_MODE=test
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Mailgun (optional — falls back to console logging)
# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.yourdomain.com

# S3-compatible storage
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET_NAME=starter-dev
S3_PUBLIC_URL=http://127.0.0.1:9000/starter-dev
S3_FORCE_PATH_STYLE=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Sentry/GlitchTip (optional)
# SENTRY_DSN=https://key@glitchtip.example.com/1
