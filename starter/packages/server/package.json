    "better-auth": "^1.6.11",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "stripe": "^22.1.1",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
