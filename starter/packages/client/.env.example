# Express API server URL (for tRPC and auth)
NEXT_PUBLIC_API_URL=http://localhost:5000

# WebSocket server URL
NEXT_PUBLIC_WS_URL=ws://localhost:5000

# OpenPanel analytics (optional)
# NEXT_PUBLIC_OPENPANEL_CLIENT_ID=your-client-id

# Sentry/GlitchTip (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://key@glitchtip.example.com/2
