{
  "name": "hatchkit-monorepo",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "private": true,
  "description": "Interactive CLI for scaffolding full-stack projects with composable ML services",
  "license": "MIT",
  "homepage": "https://hatchkit.trebeljahr.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trebeljahr/hatchkit.git"
  },
  "bugs": {
    "url": "https://github.com/trebeljahr/hatchkit/issues"
  },
  "keywords": [
    "cli",
    "scaffold",
    "typescript",
    "coolify",
    "hetzner",
    "terraform",
    "dotenvx",
    "mcp",
    "mlops"
  ],
  "scripts": {
    "build": "pnpm --filter hatchkit run build",
    "predev": "pnpm --filter @hatchkit/dev-shared run build",
    "dev": "concurrently -n shared,docs,cli,mcp -c blue,cyan,magenta,yellow \"pnpm --filter @hatchkit/dev-shared run dev\" \"pnpm -C docs run dev\" \"pnpm -C cli run dev:typecheck\" \"pnpm -C mcp run dev:typecheck\"",
    "dev:docs": "pnpm -C docs run dev",
    "dev:cli": "pnpm --filter hatchkit run dev",
    "start": "pnpm --filter hatchkit run start",
    "create": "pnpm --filter hatchkit run start",
    "typecheck": "pnpm --filter hatchkit run typecheck",
    "install-local": "pnpm --filter hatchkit run install-local",
    "release": "pnpm --filter hatchkit run release",
    "release:patch": "pnpm --filter hatchkit run release:patch",
    "release:minor": "pnpm --filter hatchkit run release:minor",
    "release:major": "pnpm --filter hatchkit run release:major"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "keytar"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
